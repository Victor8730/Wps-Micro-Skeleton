{
  "name": "webpagestudio/wps-micro-skeleton",
  "description": "Application skeleton for the WPS Micro framework",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Victor Galiuzov",
      "email": "victor8730@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "webpagestudio/wps-micro": "^3.0@dev"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist"
  },
  "archive": {
    "exclude": [
      "**/.DS_Store",
      "/.env",
      "/.idea/",
      "/node_modules/",
      "/public/build/",
      "/storage/cache/phpunit/",
      "/storage/cache/twig/",
      "/storage/logs/*.log",
      "/vendor/"
    ]
  }
}
